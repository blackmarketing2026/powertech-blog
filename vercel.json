{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.shtml"
    },
    {
      "source": "/:path((?!.*\\..*).*)",
      "destination": "/:path.shtml"
    }
  ]
}
