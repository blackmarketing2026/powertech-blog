{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.shtml"
    },
    {
      "source": "^/(?!.*\\..*$)(?!.*\\/$)(.+)$",
      "destination": "/$1.shtml"
    }
  ]
}
